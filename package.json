{
  "name": "edlics",
  "version": "1.2.0",
  "description": "Web-based file browser and editor for Linux servers",
  "bin": {
    "edlics": "./bin/edlics.js"
  },
  "preferGlobal": true,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/opermancode/edlics.git"
  },
  "bugs": {
    "url": "https://github.com/opermancode/edlics/issues"
  },
  "homepage": "https://github.com/opermancode/edlics#readme",
  "scripts": {
    "build": "esbuild bundle/editor.mjs --bundle --format=esm --outfile=public/editor.mjs --target=es2020",
    "postinstall": "npm run build"
  },
  "dependencies": {
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/lang-python": "^6.2.1",
    "@codemirror/lang-xml": "^6.1.0",
    "@codemirror/lang-yaml": "^6.1.3",
    "@codemirror/language": "^6.12.3",
    "@codemirror/state": "^6.6.0",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.42.1",
    "codemirror": "^6.0.2",
    "esbuild": "^0.28.0"
  }
}
